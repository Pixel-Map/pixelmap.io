# Copy to .env.raccoon on raccoon and fill in real values (gitignored).
# These mirror the live values from the EC2 box's /root/pixelmap.io/backend/.env
# (per the "don't rotate anything" decision — reuse the existing keys as-is).
#
# This one file is used two ways:
#   1. docker compose --env-file .env.raccoon ...  -> interpolates POSTGRES_PASSWORD
#   2. mounted read-only to /app/.env in the indexer -> godotenv.Load reads it

# --- Postgres (raccoon container) ---
# Pick any password; it is a fresh local container. Keep it in sync with the
# password embedded in DATABASE_URL below.
POSTGRES_PASSWORD=change-me-local-db-password

# The indexer connects to the compose service `postgres` on the internal
# network (port 5432 inside the compose network, NOT the 5433 host mapping).
# sslmode=disable: the local container serves plaintext.
DATABASE_URL=postgresql://postgres:change-me-local-db-password@postgres:5432/pixelmap?sslmode=disable

# Legacy individual vars (used by the old bun backend, harmless to the Go
# indexer which only reads DATABASE_URL — kept for parity).
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-me-local-db-password
DATABASE_NAME=pixelmap
DATABASE_HOST=postgres

# --- Chain + external APIs (copy real values from the EC2 box) ---
WEB3_URL=https://mainnet.infura.io/v3/REPLACE_WITH_REAL_INFURA_KEY
ETHERSCAN_API_KEY=REPLACE
OPENSEA_API_KEY=REPLACE
DISCORD_TOKEN=REPLACE

# --- S3 publish (keep serving pixelmap.art from S3/CloudFront) ---
# Leave SYNC_TO_AWS=true so this box keeps publishing renders to s3://pixelmap.art
# exactly as EC2 did. Bucket name is hardcoded in s3_syncer.go; these creds are
# the existing pixelmap S3 key (do not rotate).
SYNC_TO_AWS=true
AWS_ACCESS_KEY_ID=REPLACE_WITH_EXISTING_PIXELMAP_S3_KEY
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=us-east-1
